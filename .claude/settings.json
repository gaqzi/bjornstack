{
  "permissions": {
    "allow": [
      "Bash(bd:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnixSockets": [".git/fsmonitor--daemon.ipc"],
    "allowLocalBinding": true,
    "excludedCommands": [
      "Bash(bd:*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
